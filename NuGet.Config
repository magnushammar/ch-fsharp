<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Lock package sources to the local NuGet.org feed only. Inherited
       machine-level sources are cleared so we don't accidentally talk to
       company feeds, mirrors, or anything else that could hang. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <!-- Kill the audit-source list entirely. The audit feature otherwise hits
       GitHub Advisory DB / the audit endpoint on every restore — that's the
       network call most likely to hang a cold build. NuGetAudit=false in
       Directory.Build.props is the belt; this is the suspenders. -->
  <auditSources>
    <clear />
  </auditSources>

  <config>
    <!-- Use the default per-user packages cache; do NOT let NuGet write
         to or look up fallback folders that don't exist locally. -->
    <add key="signatureValidationMode" value="accept" />
  </config>

  <!-- No package source mapping — every package resolves from nuget.org.
       We don't share dependencies across feeds. -->
</configuration>
